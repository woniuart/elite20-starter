{
  "name": "AAR 课后复盘追踪",
  "description": "追踪 C2S 产物④：After Action Review 复盘",
  "properties": {
    "复盘主题": {
      "type": "title",
      "description": "复盘的主题或事件"
    },
    "时间线": {
      "type": "text",
      "description": "按时间顺序的关键事件"
    },
    "做得好的": {
      "type": "text",
      "description": "成功的关键因素"
    },
    "需改进的": {
      "type": "text",
      "description": "需要改进的地方"
    },
    "AI协作记录": {
      "type": "text",
      "description": "你与 AI 的交互（提示词 + AI 输出）"
    },
    "AI模型": {
      "type": "select",
      "options": ["ChatGPT-4o", "ChatGPT-4o-mini", "Claude 3.5", "Claude 3", "Gemini 2.0", "其他"],
      "description": "使用的 AI 模型"
    },
    "对话轮次": {
      "type": "number",
      "description": "本次协作的对话轮次（用户→AI 算1轮）"
    },
    "关键提示词": {
      "type": "text",
      "description": "本次协作中最重要的 1-2 条提示词"
    },
    "AI输出摘要": {
      "type": "text",
      "description": "AI 输出的核心结论或关键信息（1-3句）"
    },
    "协作质量": {
      "type": "select",
      "options": ["低", "中", "高", "优秀"],
      "description": "本次 AI 协作的帮助程度"
    },
    "对话时间": {
      "type": "date",
      "description": "本次协作的时间"
    },
    "改进计划": {
      "type": "text",
      "description": "具体的下一步行动"
    },
    "状态": {
      "type": "select",
      "options": ["未开始", "时间线整理中", "分析中", "初稿", "已完成"]
    },
    "真实性": {
      "type": "select",
      "options": ["模糊", "一般", "清晰", "生动"]
    },
    "完成度": {
      "type": "number",
      "format": "percent"
    },
    "最后修改": {
      "type": "date"
    }
  },
  "检查清单": [
    "是否有具体的时间戳事件？",
    "是否有具体的数据或事实（非泛泛而谈）？",
    "AI 协作记录是否能证明'这是你亲身经历的'？",
    "改进计划是否具体可执行？",
    "读完后是否能感受到'这 4 天真实发生了什么'？",
    "是否避免了 AI 凭空生成的通用性描述？",
    "协作轨迹是否记录了 AI 模型和对话轮次？",
    "关键提示词是否已记录（便于复现）？",
    "协作质量评估是否真实反映 AI 帮助程度？"
  ]
}
